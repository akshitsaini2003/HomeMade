{
  "info": {
    "name": "HomeMade API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Core API collection for HomeMade MERN application"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Student\",\n  \"email\": \"student3@example.com\",\n  \"phone\": \"9876500011\",\n  \"password\": \"Student@123\"\n}"
            }
          }
        },
        {
          "name": "Verify Email OTP",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/auth/verify-email",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student3@example.com\",\n  \"otp\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('userAccessToken', json.data.tokens.accessToken);",
                  "pm.collectionVariables.set('userRefreshToken', json.data.tokens.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student1@example.com\",\n  \"password\": \"Student@123\"\n}"
            }
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('adminAccessToken', json.data.tokens.accessToken);",
                  "pm.collectionVariables.set('adminRefreshToken', json.data.tokens.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Menu",
      "item": [
        {
          "name": "Create Menu (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }
            ],
            "url": "{{baseUrl}}/menus/admin",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"2026-02-17\",\n  \"platePrice\": 129,\n  \"totalPlates\": 80,\n  \"cutoffTime\": \"2026-02-16T22:00:00.000Z\",\n  \"slots\": [\"lunch\", \"dinner\"],\n  \"items\": [\n    {\n      \"name\": \"Rajma Chawal\",\n      \"description\": \"Rajma + rice + salad\",\n      \"price\": 129,\n      \"image\": \"https://images.unsplash.com/photo-1589302168068-964664d93dc0?auto=format&fit=crop&w=900&q=80\"\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Tomorrow Menu",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/menus/tomorrow"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userAccessToken}}" }
            ],
            "url": "{{baseUrl}}/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"menuId\": \"{{menuId}}\",\n  \"slot\": \"lunch\",\n  \"quantity\": 1,\n  \"walletUse\": 0,\n  \"fulfillmentType\": \"pickup\"\n}"
            }
          }
        },
        {
          "name": "My Orders",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userAccessToken}}" }
            ],
            "url": "{{baseUrl}}/orders/my?type=all"
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userAccessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/orders/my/{{orderId}}/cancel",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Need to cancel\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }
            ],
            "url": "{{baseUrl}}/admin/dashboard"
          }
        },
        {
          "name": "Orders",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }
            ],
            "url": "{{baseUrl}}/admin/orders"
          }
        },
        {
          "name": "Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }
            ],
            "url": "{{baseUrl}}/admin/users"
          }
        }
      ]
    },
    {
      "name": "Misc",
      "item": [
        {
          "name": "Submit Contact Inquiry",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/contact",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Student\",\n  \"email\": \"student1@example.com\",\n  \"phone\": \"9876543210\",\n  \"message\": \"Please share tomorrow lunch menu early.\"\n}"
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "adminEmail", "value": "admin@homemade.local" },
    { "key": "adminPassword", "value": "Admin@123" },
    { "key": "adminAccessToken", "value": "" },
    { "key": "adminRefreshToken", "value": "" },
    { "key": "userAccessToken", "value": "" },
    { "key": "userRefreshToken", "value": "" },
    { "key": "menuId", "value": "" },
    { "key": "orderId", "value": "" }
  ]
}
